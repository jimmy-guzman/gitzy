{
  "name": "gitzy",
  "version": "7.2.2",
  "description": "Conventional commits and branch CLI",
  "keywords": [
    "conventional commits",
    "cli",
    "git"
  ],
  "homepage": "https://github.com/jimmy-guzman/gitzy",
  "bugs": "https://github.com/jimmy-guzman/gitzy/issues",
  "repository": "git+https://github.com/jimmy-guzman/gitzy.git",
  "license": "MIT",
  "author": "jimmy-guzman @jimmy-guzman",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    }
  },
  "bin": "./dist/run.mjs",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "precheck": "pnpm build",
    "check": "run-p knip lint format coverage typecheck",
    "coverage": "vitest run --coverage",
    "format": "prettier --cache -c .",
    "format:fix": "prettier --cache -w .",
    "gitzy": "tsx src/run.ts",
    "knip": "knip",
    "lint": "eslint --cache .",
    "lint:fix": "pnpm lint --fix",
    "prepack": "pnpm build && clean-pkg-json",
    "prepare": "is-ci || husky",
    "test": "vitest",
    "typecheck": "tsc"
  },
  "lint-staged": {
    "*.{md,json,yml,yaml,ts}": [
      "prettier -w"
    ],
    "*.ts": [
      "eslint --fix"
    ]
  },
  "prettier": "@jimmy.codes/prettier-config",
  "devDependencies": {
    "@clack/prompts": "1.6.0",
    "@jimmy.codes/eslint-config": "8.0.1",
    "@jimmy.codes/prettier-config": "2.1.2",
    "@leeoniya/ufuzzy": "1.0.19",
    "@total-typescript/ts-reset": "0.6.1",
    "@types/node": "24.13.2",
    "@vitest/coverage-v8": "4.1.9",
    "clean-pkg-json": "2.0.0",
    "commander": "15.0.0",
    "commitlint": "21.1.0",
    "eslint": "10.5.0",
    "husky": "9.1.7",
    "is-ci": "4.1.0",
    "jiti": "2.7.0",
    "knip": "6.24.0",
    "lilconfig": "3.1.3",
    "lint-staged": "17.0.8",
    "npm-run-all2": "9.0.2",
    "prettier": "3.8.4",
    "publint": "0.3.21",
    "tinyexec": "1.2.4",
    "tsdown": "0.22.3",
    "tsx": "4.22.4",
    "typescript": "5.9.3",
    "unrun": "0.3.1",
    "valibot": "1.4.1",
    "vitest": "4.1.9"
  },
  "packageManager": "pnpm@11.5.3",
  "engines": {
    "node": "^22.13.0 || >=24"
  },
  "publishConfig": {
    "access": "public"
  }
}
